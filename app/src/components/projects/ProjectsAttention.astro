---
/*
  File: src/components/projects/ProjectsAttention.astro
  Purpose: Displays a list of projects that need attention
  Dependencies: getProjectsNeedingAttention from data/projects.ts
*/

import { getProjectsNeedingAttention } from '../../data/projects';

// Get projects that need attention
const attentionProjects = getProjectsNeedingAttention();
---

{attentionProjects.length > 0 && (
  <div class="bg-white rounded-lg shadow-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4">Projects Needing Attention</h2>
    
    <div class="space-y-3">
      {attentionProjects.map(project => {
        // Determine why project needs attention
        const needsNextSteps = !project.nextSteps || project.nextSteps.length === 0;
        const needsActivity = project.activities?.length === 0 || 
          (project.activities && new Date(project.activities[0].date) < new Date(Date.now() - 14 * 24 * 60 * 60 * 1000));
        
        return (
          <div class={`flex items-center p-3 rounded ${needsNextSteps ? 'bg-red-50 border border-red-100' : 'bg-yellow-50 border border-yellow-100'}`}>
            <div class={`w-2 h-2 rounded-full mr-3 ${needsNextSteps ? 'bg-red-500' : 'bg-yellow-500'}`}></div>
            <div class="flex-grow">
              <div class="flex justify-between items-center">
                <div>
                  <div class="font-medium">{project.title}</div>
                  <div class="text-light-ink text-sm">
                    {needsNextSteps ? 'Missing next steps' : 'No activity in 2+ weeks'}
                  </div>
                </div>
                <a href={`/project/${project.id}`} class="bg-white text-light-ink hover:text-highlight border border-gray-200 px-3 py-1 rounded text-sm flex items-center transition-colors">
                  <i class="ri-eye-line mr-1"></i> View
                </a>
              </div>
            </div>
          </div>
        )
      })}
    </div>
  </div>
)} 