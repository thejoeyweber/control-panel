---
/*
  File: src/components/projects/ProjectCard.astro
  Purpose: Reusable card component for displaying project information in a grid
  Dependencies: Project interface from data/projects.ts
*/

import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

// Status color mapping
const statusColors = {
  'active': 'bg-highlight text-white',
  'completed': 'bg-success text-white',
  'planning': 'bg-warning text-white',
  'paused': 'bg-yellow-500 text-white'
};

// Format date for display
const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
};
---

<div class="bg-white rounded-lg shadow-card overflow-hidden hover:shadow-card-hover transition-shadow">
  <div class="p-6">
    <div class="flex justify-between items-start mb-4">
      <h3 class="text-xl font-bold">{project.title}</h3>
      <span class={`text-xs px-2 py-1 rounded-full ${statusColors[project.status] || 'bg-gray-200'}`}>
        {project.status.charAt(0).toUpperCase() + project.status.slice(1)}
      </span>
    </div>
    
    <p class="text-light-ink mb-4 line-clamp-2">{project.description}</p>
    
    <div class="mb-4">
      <div class="flex justify-between text-xs text-light-ink mb-1">
        <span>Progress</span>
        <span>{project.progress}%</span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-2">
        <div 
          class="bg-highlight h-2 rounded-full" 
          style={`width: ${project.progress}%`}
        ></div>
      </div>
    </div>
    
    <div class="flex flex-wrap gap-2 mb-4">
      {project.tags && project.tags.slice(0, 3).map(tag => (
        <span class="text-xs bg-gray-100 px-2 py-1 rounded-full">{tag}</span>
      ))}
      {project.tags && project.tags.length > 3 && 
        <span class="text-xs text-light-ink">+{project.tags.length - 3} more</span>
      }
    </div>
    
    <div class="flex items-center text-sm text-light-ink">
      <i class="ri-calendar-line mr-1"></i> {formatDate(project.startDate)}
    </div>
  </div>
  
  <div class="border-t border-gray-100 p-4 bg-gray-50 flex justify-between items-center">
    <a 
      href={`/project/${project.id}`} 
      class="text-highlight hover:text-blue-700 transition-colors flex items-center">
      View details <i class="ri-arrow-right-line ml-1"></i>
    </a>
    
    <div class="flex gap-2">
      {project.githubUrl && (
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-700">
          <i class="ri-github-fill"></i>
        </a>
      )}
      {project.liveUrl && (
        <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-700">
          <i class="ri-external-link-line"></i>
        </a>
      )}
    </div>
  </div>
</div> 