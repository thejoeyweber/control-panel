---
/*
  File: src/pages/ai-library.astro
  Purpose: Displays collection of AI tools, models and resources
  Dependencies: BaseLayout
*/

import BaseLayout from '../layouts/BaseLayout.astro';
import { getVisibleContent } from '../utils/auth';
---

<BaseLayout title="AI Library" activePage="ai-library">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6">
      <h1 class="text-3xl font-bold mb-4 md:mb-0">AI Library</h1>
      <button class="bg-highlight text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors">
        <i class="ri-add-line mr-1"></i> Add Tool
      </button>
    </div>
    
    <!-- Filter Controls -->
    <div class="bg-paper border border-gray-200 rounded-lg p-4 mb-8">
      <div class="flex flex-wrap gap-4">
        <div>
          <label class="block text-sm text-light-ink mb-1">Category</label>
          <select class="border rounded px-3 py-2 w-full">
            <option>All Categories</option>
            <option>Text Generation</option>
            <option>Image Generation</option>
            <option>Code Assistance</option>
            <option>Data Analysis</option>
            <option>Productivity</option>
            <option>Research</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-light-ink mb-1">Price</label>
          <select class="border rounded px-3 py-2 w-full">
            <option>All</option>
            <option>Free</option>
            <option>Freemium</option>
            <option>Paid</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-light-ink mb-1">Rating</label>
          <select class="border rounded px-3 py-2 w-full">
            <option>Any Rating</option>
            <option>⭐⭐⭐⭐⭐</option>
            <option>⭐⭐⭐⭐ & up</option>
            <option>⭐⭐⭐ & up</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-light-ink mb-1">Search</label>
          <input type="text" placeholder="Search AI tools..." class="border rounded px-3 py-2 w-full" />
        </div>
        <div class="flex-1"></div>
        <div class="flex items-end">
          <button class="bg-highlight text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors">
            Apply Filters
          </button>
        </div>
      </div>
    </div>
    
    <!-- AI Tools Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-8">
      <!-- Tool Card 1 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="h-40 bg-gray-100 relative overflow-hidden">
          <img 
            src="https://placehold.co/600x400/e0f2fe/1e40af?text=Claude+AI" 
            alt="Claude AI" 
            class="w-full h-full object-cover"
          />
          <div class="absolute top-2 right-2">
            <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Text Generation</span>
          </div>
        </div>
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <h3 class="text-lg font-bold">Claude AI</h3>
            <div class="text-amber-400 text-sm">
              ⭐⭐⭐⭐⭐ <span class="text-light-ink">(5.0)</span>
            </div>
          </div>
          <p class="text-sm text-light-ink mb-4">Advanced AI assistant from Anthropic with strong reasoning, safety, and helpfulness.</p>
          <div class="flex justify-between text-sm mb-1">
            <span>Pricing</span>
            <span class="font-semibold">Freemium</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span>Last Used</span>
            <span>Today</span>
          </div>
          <div class="flex justify-between text-sm">
            <span>Use Cases</span>
            <span>Writing, Research, Code</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <a href="https://claude.ai" target="_blank" class="text-highlight hover:underline text-sm">
            <i class="ri-external-link-line mr-1"></i> Open
          </a>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
      
      <!-- Tool Card 2 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="h-40 bg-gray-100 relative overflow-hidden">
          <img 
            src="https://placehold.co/600x400/f0fdf4/166534?text=Midjourney" 
            alt="Midjourney" 
            class="w-full h-full object-cover"
          />
          <div class="absolute top-2 right-2">
            <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">Image Generation</span>
          </div>
        </div>
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <h3 class="text-lg font-bold">Midjourney</h3>
            <div class="text-amber-400 text-sm">
              ⭐⭐⭐⭐⭐ <span class="text-light-ink">(4.8)</span>
            </div>
          </div>
          <p class="text-sm text-light-ink mb-4">High-quality AI image generation tool for creating detailed, artistic visuals from text prompts.</p>
          <div class="flex justify-between text-sm mb-1">
            <span>Pricing</span>
            <span class="font-semibold">Paid ($10-$30/mo)</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span>Last Used</span>
            <span>2 days ago</span>
          </div>
          <div class="flex justify-between text-sm">
            <span>Use Cases</span>
            <span>Design, Illustration, Concept Art</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <a href="https://midjourney.com" target="_blank" class="text-highlight hover:underline text-sm">
            <i class="ri-external-link-line mr-1"></i> Open
          </a>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
      
      <!-- Tool Card 3 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="h-40 bg-gray-100 relative overflow-hidden">
          <img 
            src="https://placehold.co/600x400/fef2f2/991b1b?text=GitHub+Copilot" 
            alt="GitHub Copilot" 
            class="w-full h-full object-cover"
          />
          <div class="absolute top-2 right-2">
            <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded">Code Assistance</span>
          </div>
        </div>
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <h3 class="text-lg font-bold">GitHub Copilot</h3>
            <div class="text-amber-400 text-sm">
              ⭐⭐⭐⭐ <span class="text-light-ink">(4.5)</span>
            </div>
          </div>
          <p class="text-sm text-light-ink mb-4">AI pair programmer that suggests code completions as you type, based on context and comments.</p>
          <div class="flex justify-between text-sm mb-1">
            <span>Pricing</span>
            <span class="font-semibold">Paid ($10/mo)</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span>Last Used</span>
            <span>Yesterday</span>
          </div>
          <div class="flex justify-between text-sm">
            <span>Use Cases</span>
            <span>Coding, Development, Testing</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <a href="https://github.com/features/copilot" target="_blank" class="text-highlight hover:underline text-sm">
            <i class="ri-external-link-line mr-1"></i> Open
          </a>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
      
      <!-- Tool Card 4 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="h-40 bg-gray-100 relative overflow-hidden">
          <img 
            src="https://placehold.co/600x400/f0f9ff/0c4a6e?text=Cursor" 
            alt="Cursor" 
            class="w-full h-full object-cover"
          />
          <div class="absolute top-2 right-2">
            <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Code Assistance</span>
          </div>
        </div>
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <h3 class="text-lg font-bold">Cursor</h3>
            <div class="text-amber-400 text-sm">
              ⭐⭐⭐⭐⭐ <span class="text-light-ink">(4.7)</span>
            </div>
          </div>
          <p class="text-sm text-light-ink mb-4">AI-powered code editor built on VSCode with integrated Claude AI for better context understanding.</p>
          <div class="flex justify-between text-sm mb-1">
            <span>Pricing</span>
            <span class="font-semibold">Freemium</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span>Last Used</span>
            <span>Today</span>
          </div>
          <div class="flex justify-between text-sm">
            <span>Use Cases</span>
            <span>Coding, Refactoring, Documentation</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <a href="https://cursor.sh" target="_blank" class="text-highlight hover:underline text-sm">
            <i class="ri-external-link-line mr-1"></i> Open
          </a>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
    </div>
    
    <!-- Recently Used Tools -->
    <div class="bg-white rounded-lg shadow-card overflow-hidden">
      <div class="flex justify-between items-center p-4 border-b border-gray-200">
        <h3 class="text-lg font-bold">Recently Used</h3>
        <button class="text-highlight hover:underline text-sm">View History</button>
      </div>
      
      <div class="divide-y">
        <div class="p-4 hover:bg-gray-50 flex items-center">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 mr-3">
            <i class="ri-robot-line text-lg"></i>
          </div>
          <div class="flex-grow">
            <h4 class="font-semibold">Claude AI</h4>
            <p class="text-xs text-light-ink">Used 2 hours ago - Writing assistance</p>
          </div>
          <a href="https://claude.ai" class="text-highlight hover:underline text-sm">
            <i class="ri-external-link-line"></i>
          </a>
        </div>
        <div class="p-4 hover:bg-gray-50 flex items-center">
          <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center text-red-600 mr-3">
            <i class="ri-code-line text-lg"></i>
          </div>
          <div class="flex-grow">
            <h4 class="font-semibold">Cursor</h4>
            <p class="text-xs text-light-ink">Used 4 hours ago - Code refactoring</p>
          </div>
          <a href="https://cursor.sh" class="text-highlight hover:underline text-sm">
            <i class="ri-external-link-line"></i>
          </a>
        </div>
        <div class="p-4 hover:bg-gray-50 flex items-center">
          <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-600 mr-3">
            <i class="ri-image-line text-lg"></i>
          </div>
          <div class="flex-grow">
            <h4 class="font-semibold">DALL-E 3</h4>
            <p class="text-xs text-light-ink">Used yesterday - Project illustrations</p>
          </div>
          <a href="https://openai.com/dall-e-3" class="text-highlight hover:underline text-sm">
            <i class="ri-external-link-line"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout> 