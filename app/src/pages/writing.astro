---
/*
  File: src/pages/writing.astro
  Purpose: Displays user's writing projects, notes, and drafts
  Dependencies: BaseLayout, writing data
*/

import BaseLayout from '../layouts/BaseLayout.astro';
import { getVisibleWriting, getWritingStats } from '../data/writing';

// Get visible writing content and stats
const writingPieces = getVisibleWriting();
const stats = getWritingStats();

// Filter pieces by status
const published = writingPieces.filter(piece => piece.status === 'published');
const drafts = writingPieces.filter(piece => piece.status === 'draft');
const scheduled = writingPieces.filter(piece => piece.status === 'scheduled');
---

<BaseLayout title="Writing" activePage="writing">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6">
      <h1 class="text-3xl font-bold mb-4 md:mb-0">Writing</h1>
      <div class="flex gap-2">
        <button class="bg-highlight text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors">
          <i class="ri-add-line mr-1"></i> New Project
        </button>
        <button class="bg-paper text-ink border border-gray-300 px-4 py-2 rounded hover:bg-gray-100 transition-colors">
          <i class="ri-edit-line mr-1"></i> Quick Note
        </button>
      </div>
    </div>
    
    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-lg shadow-card p-4">
        <h3 class="text-sm text-light-ink mb-1">Active Projects</h3>
        <p class="text-2xl font-bold">{stats.total}</p>
      </div>
      <div class="bg-white rounded-lg shadow-card p-4">
        <h3 class="text-sm text-light-ink mb-1">Published</h3>
        <p class="text-2xl font-bold">{stats.published}</p>
      </div>
      <div class="bg-white rounded-lg shadow-card p-4">
        <h3 class="text-sm text-light-ink mb-1">In Draft</h3>
        <p class="text-2xl font-bold">{stats.drafts}</p>
      </div>
      <div class="bg-white rounded-lg shadow-card p-4">
        <h3 class="text-sm text-light-ink mb-1">Total Words</h3>
        <p class="text-2xl font-bold">{stats.totalWords.toLocaleString()}</p>
      </div>
    </div>
    
    <!-- Filter Controls -->
    <div class="bg-paper border border-gray-200 rounded-lg p-4 mb-8">
      <div class="flex flex-wrap gap-4">
        <div>
          <label class="block text-sm text-light-ink mb-1">Status</label>
          <select class="border rounded px-3 py-2 w-full">
            <option>All</option>
            <option>In Progress</option>
            <option>Draft</option>
            <option>Published</option>
            <option>Archived</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-light-ink mb-1">Category</label>
          <select class="border rounded px-3 py-2 w-full">
            <option>All</option>
            <option>Blog Posts</option>
            <option>Articles</option>
            <option>Newsletter</option>
            <option>Book</option>
            <option>Academic</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-light-ink mb-1">Search</label>
          <input type="text" placeholder="Search writing..." class="border rounded px-3 py-2 w-full" />
        </div>
        <div class="flex-1"></div>
        <div class="flex items-end">
          <button class="bg-highlight text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors">
            Apply Filters
          </button>
        </div>
      </div>
    </div>
    
    <!-- Writing Projects -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-8">
      <!-- Project Card 1 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="p-4 border-b border-gray-200">
          <div class="flex justify-between items-start">
            <h3 class="text-lg font-bold">The Future of AI in Content Creation</h3>
            <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">In Progress</span>
          </div>
          <p class="text-sm text-light-ink mt-2">A comprehensive analysis of how AI tools are transforming the content creation landscape.</p>
        </div>
        <div class="p-4">
          <div class="flex justify-between text-sm mb-2">
            <span>Category</span>
            <span>Blog Post</span>
          </div>
          <div class="flex justify-between text-sm mb-2">
            <span>Current Word Count</span>
            <span>1,450 / 2,000</span>
          </div>
          <div class="flex justify-between text-sm mb-2">
            <span>Due Date</span>
            <span>Mar 15, 2025</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2 mt-3">
            <div class="bg-highlight h-2 rounded-full" style="width: 72%"></div>
          </div>
          <div class="flex justify-between text-xs text-light-ink mt-1">
            <span>Progress</span>
            <span>72%</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-edit-line mr-1"></i> Edit
          </button>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
      
      <!-- Project Card 2 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="p-4 border-b border-gray-200">
          <div class="flex justify-between items-start">
            <h3 class="text-lg font-bold">Getting Started with Astro Framework</h3>
            <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">Published</span>
          </div>
          <p class="text-sm text-light-ink mt-2">A beginner's guide to building static and partially hydrated sites with Astro.</p>
        </div>
        <div class="p-4">
          <div class="flex justify-between text-sm mb-2">
            <span>Category</span>
            <span>Tutorial</span>
          </div>
          <div class="flex justify-between text-sm mb-2">
            <span>Final Word Count</span>
            <span>2,850</span>
          </div>
          <div class="flex justify-between text-sm mb-2">
            <span>Published On</span>
            <span>Feb 10, 2025</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2 mt-3">
            <div class="bg-success h-2 rounded-full" style="width: 100%"></div>
          </div>
          <div class="flex justify-between text-xs text-light-ink mt-1">
            <span>Views</span>
            <span>1,245</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-eye-line mr-1"></i> View
          </button>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
      
      <!-- Project Card 3 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="p-4 border-b border-gray-200">
          <div class="flex justify-between items-start">
            <h3 class="text-lg font-bold">Sustainable Development Approaches</h3>
            <span class="bg-amber-100 text-amber-800 text-xs px-2 py-1 rounded">Draft</span>
          </div>
          <p class="text-sm text-light-ink mt-2">Exploring sustainable development practices for modern software engineering teams.</p>
        </div>
        <div class="p-4">
          <div class="flex justify-between text-sm mb-2">
            <span>Category</span>
            <span>Article</span>
          </div>
          <div class="flex justify-between text-sm mb-2">
            <span>Current Word Count</span>
            <span>850 / 3,000</span>
          </div>
          <div class="flex justify-between text-sm mb-2">
            <span>Started On</span>
            <span>Feb 5, 2025</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2 mt-3">
            <div class="bg-amber-500 h-2 rounded-full" style="width: 28%"></div>
          </div>
          <div class="flex justify-between text-xs text-light-ink mt-1">
            <span>Progress</span>
            <span>28%</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-edit-line mr-1"></i> Edit
          </button>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
    </div>
    
    <!-- Notes and Ideas -->
    <div class="bg-white rounded-lg shadow-card overflow-hidden">
      <div class="flex justify-between items-center p-4 border-b border-gray-200">
        <h3 class="text-lg font-bold">Quick Notes & Ideas</h3>
        <button class="text-highlight hover:underline text-sm">View All</button>
      </div>
      
      <div class="divide-y">
        <div class="p-4 hover:bg-gray-50">
          <div class="flex justify-between mb-1">
            <h4 class="font-semibold">Feature comparison: Astro vs Next.js</h4>
            <span class="text-xs text-light-ink">2 days ago</span>
          </div>
          <p class="text-sm text-light-ink">Compare build times, performance metrics, and developer experience between the two frameworks.</p>
        </div>
        <div class="p-4 hover:bg-gray-50">
          <div class="flex justify-between mb-1">
            <h4 class="font-semibold">Newsletter topics for March</h4>
            <span class="text-xs text-light-ink">4 days ago</span>
          </div>
          <p class="text-sm text-light-ink">1. New Tailwind features, 2. Astro integrations, 3. Accessibility tips for SPAs</p>
        </div>
        <div class="p-4 hover:bg-gray-50">
          <div class="flex justify-between mb-1">
            <h4 class="font-semibold">Book chapter outline</h4>
            <span class="text-xs text-light-ink">1 week ago</span>
          </div>
          <p class="text-sm text-light-ink">Structure for Chapter 4: Testing strategies for modern web applications</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout> 