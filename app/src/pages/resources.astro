---
/*
  File: src/pages/resources.astro
  Purpose: Displays collection of learning resources, articles, courses, and reference materials
  Dependencies: BaseLayout, resources data
*/

import BaseLayout from '../layouts/BaseLayout.astro';
import { getVisibleResources, getResourceStats, getFavoriteResources } from '../data/resources';

// Get visible resources and stats
const allResources = getVisibleResources();
const stats = getResourceStats();
const favorites = getFavoriteResources();

// Get unique categories for filtering
const categories = [...new Set(allResources.map(resource => resource.category))];
---

<BaseLayout title="Resources" activePage="resources">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6">
      <h1 class="text-3xl font-bold mb-4 md:mb-0">Resources</h1>
      <button class="bg-highlight text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors">
        <i class="ri-add-line mr-1"></i> Add Resource
      </button>
    </div>
    
    <!-- Filter Controls -->
    <div class="bg-paper border border-gray-200 rounded-lg p-4 mb-8">
      <div class="flex flex-wrap gap-4">
        <div>
          <label class="block text-sm text-light-ink mb-1">Category</label>
          <select class="border rounded px-3 py-2 w-full">
            <option>All Categories</option>
            {categories.map(category => (
              <option>{category}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-sm text-light-ink mb-1">Tags</label>
          <select class="border rounded px-3 py-2 w-full">
            <option>All Tags</option>
            <option>Astro</option>
            <option>React</option>
            <option>JavaScript</option>
            <option>Tailwind</option>
            <option>Design</option>
            <option>Architecture</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-light-ink mb-1">Status</label>
          <select class="border rounded px-3 py-2 w-full">
            <option>All</option>
            <option>To Read</option>
            <option>In Progress</option>
            <option>Completed</option>
            <option>Reference</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-light-ink mb-1">Search</label>
          <input type="text" placeholder="Search resources..." class="border rounded px-3 py-2 w-full" />
        </div>
        <div class="flex-1"></div>
        <div class="flex items-end">
          <button class="bg-highlight text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors">
            Apply Filters
          </button>
        </div>
      </div>
    </div>
    
    <!-- Resources Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-8">
      <!-- Resource Card 1 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="h-32 bg-gradient-to-r from-blue-500 to-indigo-600 flex items-center justify-center text-white px-4">
          <span class="text-xl font-bold">Astro 3.0 Documentation</span>
        </div>
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <div>
              <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded mr-1">Documentation</span>
              <span class="bg-indigo-100 text-indigo-800 text-xs px-2 py-1 rounded">Reference</span>
            </div>
            <div class="text-amber-400 text-sm">
              ⭐⭐⭐⭐⭐
            </div>
          </div>
          <p class="text-sm text-light-ink my-3">Comprehensive documentation for Astro 3.0, including guides, API references, and examples.</p>
          <div class="flex justify-between text-sm mb-1">
            <span>Added</span>
            <span>Mar 1, 2025</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span>Status</span>
            <span class="font-semibold">Reference</span>
          </div>
          <div class="flex flex-wrap gap-1 mt-3">
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">astro</span>
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">docs</span>
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">web-dev</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <a href="https://docs.astro.build" target="_blank" class="text-highlight hover:underline text-sm">
            <i class="ri-external-link-line mr-1"></i> Open
          </a>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
      
      <!-- Resource Card 2 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="h-32 bg-gradient-to-r from-amber-500 to-orange-600 flex items-center justify-center text-white px-4">
          <span class="text-xl font-bold">Modern Frontend Architecture</span>
        </div>
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <div>
              <span class="bg-amber-100 text-amber-800 text-xs px-2 py-1 rounded mr-1">Course</span>
              <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded">In Progress</span>
            </div>
            <div class="text-amber-400 text-sm">
              ⭐⭐⭐⭐
            </div>
          </div>
          <p class="text-sm text-light-ink my-3">Comprehensive course on building scalable and maintainable frontend architectures with modern tools.</p>
          <div class="flex justify-between text-sm mb-1">
            <span>Added</span>
            <span>Feb 15, 2025</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span>Progress</span>
            <span class="font-semibold">4/8 modules</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2 mt-1 mb-3">
            <div class="bg-amber-500 h-2 rounded-full" style="width: 50%"></div>
          </div>
          <div class="flex flex-wrap gap-1">
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">architecture</span>
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">frontend</span>
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">patterns</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <a href="#" class="text-highlight hover:underline text-sm">
            <i class="ri-book-open-line mr-1"></i> Continue
          </a>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
      
      <!-- Resource Card 3 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="h-32 bg-gradient-to-r from-green-500 to-teal-600 flex items-center justify-center text-white px-4">
          <span class="text-xl font-bold">Advanced Tailwind Techniques</span>
        </div>
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <div>
              <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded mr-1">Article</span>
              <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded">To Read</span>
            </div>
            <div class="text-amber-400 text-sm">
              ⭐⭐⭐⭐⭐
            </div>
          </div>
          <p class="text-sm text-light-ink my-3">In-depth article covering advanced techniques, custom plugins, and optimization strategies for Tailwind CSS.</p>
          <div class="flex justify-between text-sm mb-1">
            <span>Added</span>
            <span>Feb 28, 2025</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span>Read Time</span>
            <span class="font-semibold">15 min</span>
          </div>
          <div class="flex flex-wrap gap-1 mt-3">
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">tailwind</span>
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">css</span>
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">design-systems</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <a href="#" class="text-highlight hover:underline text-sm">
            <i class="ri-file-text-line mr-1"></i> Read
          </a>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
      
      <!-- Resource Card 4 -->
      <div class="bg-white rounded-lg shadow-card overflow-hidden">
        <div class="h-32 bg-gradient-to-r from-purple-500 to-pink-600 flex items-center justify-center text-white px-4">
          <span class="text-xl font-bold">Web Performance Masterclass</span>
        </div>
        <div class="p-4">
          <div class="flex justify-between items-start mb-2">
            <div>
              <span class="bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded mr-1">Video Series</span>
              <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">Completed</span>
            </div>
            <div class="text-amber-400 text-sm">
              ⭐⭐⭐⭐
            </div>
          </div>
          <p class="text-sm text-light-ink my-3">Video series on optimizing web applications for performance, covering loading, rendering, and runtime optimizations.</p>
          <div class="flex justify-between text-sm mb-1">
            <span>Completed</span>
            <span>Feb 10, 2025</span>
          </div>
          <div class="flex justify-between text-sm mb-1">
            <span>Duration</span>
            <span class="font-semibold">3h 45m</span>
          </div>
          <div class="flex flex-wrap gap-1 mt-3">
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">performance</span>
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">optimization</span>
            <span class="bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">web-vitals</span>
          </div>
        </div>
        <div class="bg-gray-50 p-3 flex justify-between border-t border-gray-200">
          <a href="#" class="text-highlight hover:underline text-sm">
            <i class="ri-video-line mr-1"></i> Rewatch
          </a>
          <button class="text-highlight hover:underline text-sm">
            <i class="ri-more-line"></i>
          </button>
        </div>
      </div>
    </div>
    
    <!-- Recently Added Resources -->
    <div class="bg-white rounded-lg shadow-card overflow-hidden mb-8">
      <div class="flex justify-between items-center p-4 border-b border-gray-200">
        <h3 class="text-lg font-bold">Recently Added</h3>
        <button class="text-highlight hover:underline text-sm">View All</button>
      </div>
      
      <div class="divide-y">
        <div class="p-4 hover:bg-gray-50 flex items-center">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 mr-3">
            <i class="ri-article-line text-lg"></i>
          </div>
          <div class="flex-grow">
            <h4 class="font-semibold">Building a Design System with Tailwind</h4>
            <p class="text-xs text-light-ink">Article • Added 2 days ago</p>
          </div>
          <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded">
            To Read
          </span>
        </div>
        <div class="p-4 hover:bg-gray-50 flex items-center">
          <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-600 mr-3">
            <i class="ri-video-line text-lg"></i>
          </div>
          <div class="flex-grow">
            <h4 class="font-semibold">Mastering Astro Islands Architecture</h4>
            <p class="text-xs text-light-ink">Video • Added 3 days ago</p>
          </div>
          <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded">
            In Progress
          </span>
        </div>
        <div class="p-4 hover:bg-gray-50 flex items-center">
          <div class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center text-amber-600 mr-3">
            <i class="ri-book-line text-lg"></i>
          </div>
          <div class="flex-grow">
            <h4 class="font-semibold">Refactoring UI</h4>
            <p class="text-xs text-light-ink">Book • Added 1 week ago</p>
          </div>
          <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">
            Completed
          </span>
        </div>
      </div>
    </div>
    
    <!-- Resource Collections -->
    <div class="bg-white rounded-lg shadow-card overflow-hidden">
      <div class="flex justify-between items-center p-4 border-b border-gray-200">
        <h3 class="text-lg font-bold">Collections</h3>
        <button class="text-highlight hover:underline text-sm">Manage Collections</button>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 p-4">
        <div class="border border-gray-200 rounded-lg p-3 hover:bg-gray-50 transition-colors">
          <h4 class="font-semibold mb-1">Astro Learning Path</h4>
          <p class="text-xs text-light-ink mb-2">7 resources • Created Mar 1, 2025</p>
          <div class="flex justify-between text-xs">
            <span>Progress</span>
            <span>3/7 completed</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-1.5 mt-1">
            <div class="bg-highlight h-1.5 rounded-full" style="width: 42%"></div>
          </div>
        </div>
        <div class="border border-gray-200 rounded-lg p-3 hover:bg-gray-50 transition-colors">
          <h4 class="font-semibold mb-1">Web Performance</h4>
          <p class="text-xs text-light-ink mb-2">5 resources • Created Feb 15, 2025</p>
          <div class="flex justify-between text-xs">
            <span>Progress</span>
            <span>4/5 completed</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-1.5 mt-1">
            <div class="bg-highlight h-1.5 rounded-full" style="width: 80%"></div>
          </div>
        </div>
        <div class="border border-gray-200 rounded-lg p-3 hover:bg-gray-50 transition-colors">
          <h4 class="font-semibold mb-1">Design Principles</h4>
          <p class="text-xs text-light-ink mb-2">6 resources • Created Jan 20, 2025</p>
          <div class="flex justify-between text-xs">
            <span>Progress</span>
            <span>6/6 completed</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-1.5 mt-1">
            <div class="bg-success h-1.5 rounded-full" style="width: 100%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout> 