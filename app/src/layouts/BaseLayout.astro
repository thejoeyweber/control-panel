---
/*
  File: src/layouts/BaseLayout.astro
  Purpose: Provides the base layout structure for all pages, including common elements like header, navigation, and footer.
  Dependencies: Tailwind CSS, Remix Icons
*/

import '../styles/global.css';

export interface Props {
  title: string;
  activePage?: 'dashboard' | 'projects' | 'revenue' | 'writing' | 'ai-library' | 'resources' | 'books' | 'activity-dashboard';
}

const { title, activePage = 'dashboard' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-paper">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} - Control Panel</title>
    <!-- Preload fonts to prevent FOUT (Flash of Unstyled Text) -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Special+Elite&display=swap" as="style">
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" as="style">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Special+Elite&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css">
    <style>
      /* Critical CSS to prevent layout shifts */
      html {
        overflow-y: scroll; /* Always show scrollbar to prevent layout shifts */
      }
      
      /* Hide content until fonts are loaded */
      .fonts-loading {
        visibility: hidden;
      }
      
      .fonts-loaded {
        visibility: visible;
        transition: opacity 0.3s ease;
      }
    </style>
    <slot name="head" />
  </head>
  <body class="text-ink bg-paper min-h-screen font-typewriter">
    <div class="wrapper mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <!-- Header -->
      <header class="py-4 border-b border-gray-200 dark:border-gray-700">
        <div class="flex justify-between items-center">
          <a href="/" class="text-2xl font-bold hover:text-highlight transition-colors">Control Panel</a>
          
          <!-- Navigation for desktop -->
          <nav id="nav-menu" class="hidden md:block">
            <ul class="flex space-x-4">
              <li><a href="/" class={`nav-dashboard flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'dashboard' ? 'active bg-highlight text-white' : ''}`}><i class="ri-dashboard-line mr-2"></i> Dashboard</a></li>
              <li><a href="/projects" class={`nav-projects flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'projects' ? 'active bg-highlight text-white' : ''}`}><i class="ri-folder-line mr-2"></i> Projects</a></li>
              <li><a href="/revenue" class={`nav-revenue flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'revenue' ? 'active bg-highlight text-white' : ''}`}><i class="ri-money-dollar-circle-line mr-2"></i> Revenue</a></li>
              <li><a href="/writing" class={`nav-writing flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'writing' ? 'active bg-highlight text-white' : ''}`}><i class="ri-edit-line mr-2"></i> Writing</a></li>
              <li><a href="/ai-library" class={`nav-ai-library flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'ai-library' ? 'active bg-highlight text-white' : ''}`}><i class="ri-robot-line mr-2"></i> AI Library</a></li>
              <li><a href="/resources" class={`nav-resources flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'resources' ? 'active bg-highlight text-white' : ''}`}><i class="ri-link-m mr-2"></i> Resources</a></li>
              <li><a href="/books" class={`nav-books flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'books' ? 'active bg-highlight text-white' : ''}`}><i class="ri-book-read-line mr-2"></i> Books</a></li>
            </ul>
          </nav>
          
          <!-- Hamburger button for mobile -->
          <button id="hamburger" class="md:hidden flex flex-col justify-center items-center w-10 h-10 space-y-2 cursor-pointer z-50">
            <span class="hamburger-line block w-6 h-0.5 bg-ink dark:bg-white rounded-full origin-center transition-all duration-300"></span>
            <span class="hamburger-line block w-6 h-0.5 bg-ink dark:bg-white rounded-full origin-center transition-all duration-300"></span>
            <span class="hamburger-line block w-6 h-0.5 bg-ink dark:bg-white rounded-full origin-center transition-all duration-300"></span>
          </button>
        </div>
        
        <!-- Mobile navigation menu - Will push content down when opened -->
        <div id="mobile-menu" class="md:hidden hidden mt-4 transition-all duration-300 ease-in-out border-t border-gray-200 pt-4">
          <ul class="flex flex-col space-y-2">
            <li><a href="/" class={`nav-dashboard flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'dashboard' ? 'active bg-highlight text-white' : ''}`}><i class="ri-dashboard-line mr-2"></i> Dashboard</a></li>
            <li><a href="/projects" class={`nav-projects flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'projects' ? 'active bg-highlight text-white' : ''}`}><i class="ri-folder-line mr-2"></i> Projects</a></li>
            <li><a href="/revenue" class={`nav-revenue flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'revenue' ? 'active bg-highlight text-white' : ''}`}><i class="ri-money-dollar-circle-line mr-2"></i> Revenue</a></li>
            <li><a href="/writing" class={`nav-writing flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'writing' ? 'active bg-highlight text-white' : ''}`}><i class="ri-edit-line mr-2"></i> Writing</a></li>
            <li><a href="/ai-library" class={`nav-ai-library flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'ai-library' ? 'active bg-highlight text-white' : ''}`}><i class="ri-robot-line mr-2"></i> AI Library</a></li>
            <li><a href="/resources" class={`nav-resources flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'resources' ? 'active bg-highlight text-white' : ''}`}><i class="ri-link-m mr-2"></i> Resources</a></li>
            <li><a href="/books" class={`nav-books flex items-center px-4 py-2 hover:bg-gray-100 hover:text-white dark:hover:bg-gray-700 transition-colors rounded ${activePage === 'books' ? 'active bg-highlight text-white' : ''}`}><i class="ri-book-read-line mr-2"></i> Books</a></li>
          </ul>
        </div>
      </header>
      
      <!-- Main content -->
      <main class="py-6">
        <slot />
      </main>
      
      <!-- Footer -->
      <footer class="py-4 text-center text-sm text-light-ink border-t border-gray-200 dark:border-gray-700">
        <p>© 2025 Control Panel - Personal Dashboard</p>
      </footer>
    </div>
    
    <script>
      // Font loading diagnostics
      console.log('[FONTS] Starting font loading diagnostics');
      
      // Add class to indicate fonts are loading
      document.documentElement.classList.add('fonts-loading');
      
      // Check if the browser supports the Font Loading API
      if ('fonts' in document) {
        console.log('[FONTS] Font Loading API is supported');
        
        // Create a promise that resolves when the font is loaded
        document.fonts.ready.then(function() {
          console.log('[FONTS] All fonts are loaded');
          document.documentElement.classList.remove('fonts-loading');
          document.documentElement.classList.add('fonts-loaded');
        });
      } else {
        console.log('[FONTS] Font Loading API is not supported');
        
        // Fallback for browsers that don't support the Font Loading API
        // Remove the loading class after a short delay
        setTimeout(function() {
          console.log('[FONTS] Fallback timeout completed');
          document.documentElement.classList.remove('fonts-loading');
          document.documentElement.classList.add('fonts-loaded');
        }, 500);
      }
      
      // Mobile menu toggle
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      
      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
          // Toggle hamburger animation
          hamburger.querySelectorAll('.hamburger-line').forEach((line, index) => {
            if (index === 0) {
              line.classList.toggle('rotate-45');
              line.classList.toggle('translate-y-2.5');
            } else if (index === 1) {
              line.classList.toggle('opacity-0');
            } else if (index === 2) {
              line.classList.toggle('-rotate-45');
              line.classList.toggle('-translate-y-2.5');
            }
          });
        });
      }
    </script>
  </body>
</html> 