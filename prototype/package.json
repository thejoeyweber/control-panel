{
  "name": "controlpanel",
  "version": "1.0.0",
  "description": "A personal control panel for managing projects, revenue, writing, and resources",
  "main": "index.js",
  "scripts": {
    "dev": "npx tailwindcss -i ./css/tailwind.css -o ./css/styles.css --watch",
    "build": "npx tailwindcss -i ./css/tailwind.css -o ./css/styles.css --minify",
    "build:pages": "node js/build-pages.js",
    "build:all": "node build.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run build:all && serve dist -p 3000",
    "serve": "serve dist -p 3000"
  },
  "keywords": [
    "dashboard",
    "control-panel",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.24",
    "serve": "^14.2.4",
    "tailwindcss": "^3.3.3"
  },
  "dependencies": {
    "browserslist": "^4.24.4",
    "caniuse-lite": "^1.0.30001701",
    "electron-to-chromium": "^1.5.109",
    "escalade": "^3.2.0",
    "postcss-value-parser": "^4.2.0",
    "update-browserslist-db": "^1.1.3"
  }
}
